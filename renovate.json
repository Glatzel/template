{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "* * * * 1"
  ],
  "enabledManagers": [
    "github-actions",
    "pixi",
    "cargo",
    "nuget",
    "dockerfile",
    "docker-compose",
    "devcontainer"
  ],
  "commitMessagePrefix": "build:",
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "groupName": "Pixi",
      "matchManagers": [
        "pixi"
      ],
      "registryUrls": [
        "https://prefix.dev/glatzel/",
        "https://prefix.dev/conda-forge/"
      ]
    },
    {
      "description": "Disable update python and numpy",
      "matchManagers": [
        "pixi"
      ],
      "matchPackageNames": [
        "python",
        "numpy"
      ],
      "enabled": false
    },
    {
      "description": "lefthook",
      "matchManagers": [
        "pixi"
      ],
      "matchFileNames": [
        "lefthook/**"
      ]
    },
    {
      "groupName": "Cargo",
      "matchManagers": [
        "cargo"
      ]
    },
    {
      "groupName": "Dotnet",
      "matchManagers": [
        "nuget"
      ]
    },
    {
      "groupName": "git-submodules",
      "matchManagers": [
        "git-submodules"
      ]
    }
  ]
}
